APP_ENV=production

# En el servidor de Hostinger usar localhost; en local usar srv458.hstgr.io
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u127814904_sensores

# Recomendado: usuario de DB dedicado SOLO para la ingesta
# (presupuesto de conexiones aislado del dashboard)
DB_USER=u127814904_sensores_ingest
DB_PASS=
DB_CHARSET=utf8mb4

APP_TIMEZONE=America/Mexico_City

# ── RabbitMQ (CloudAMQP) — alertas ──
RABBITMQ_HOST=fish-01.rmq.cloudamqp.com
RABBITMQ_PORT=5672
RABBITMQ_USER=
RABBITMQ_PASS=
RABBITMQ_VHOST=

# ── MQTT — tiempo real ──
MQTT_HOST=mqtt.gnssys.com
MQTT_PORT=1883
MQTT_USER=telemetry
MQTT_PASSWORD=
MQTT_CLIENT_PREFIX=telemetry-api-
MQTT_TOPIC_PREFIX=telemetry
MQTT_RETAIN=false
MQTT_ENABLED=true
MQTT_TIMEOUT=2
